PORT=5000
NODE_ENV=development

# PostgreSQL (Neon / Supabase / local)
# Example Neon: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://app_user:app_password123@localhost:5432/smart_recommend_ai

# JWT
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
SIGNUP_BONUS_CREDITS=5
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Stripe (test mode) — create a free account at https://dashboard.stripe.com/register,
# grab your TEST keys from https://dashboard.stripe.com/test/apikeys, and create a
# recurring "Pro" Price in https://dashboard.stripe.com/test/products to get a price ID.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
