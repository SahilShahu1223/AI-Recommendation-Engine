# This root .env file is only used by docker-compose.yml (Path B in
# AWS_DEPLOYMENT.md) to configure the mysql, backend, and frontend containers
# together. For local development without Docker, see backend/.env.example
# and frontend/.env.example instead — each service reads its own .env there.

# --- MySQL container ---
MYSQL_ROOT_PASSWORD=change_this_root_password
DB_NAME=smart_recommend_ai
DB_USER=app_user
DB_PASSWORD=change_this_app_user_password

# --- Backend container ---
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SIGNUP_BONUS_CREDITS=5
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Frontend container (baked in at build time) ---
VITE_API_URL=http://localhost:5000/api
