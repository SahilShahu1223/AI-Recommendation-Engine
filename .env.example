# Root environment template for Docker Compose (local PostgreSQL stack).
# For Vercel deployment, set DATABASE_URL and other secrets in the Vercel dashboard.
# For local dev without Docker, see backend/.env.example and frontend/.env.example.

# --- PostgreSQL container ---
POSTGRES_DB=smart_recommend_ai
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change_this_app_user_password

# --- Backend ---
DATABASE_URL=postgresql://app_user:change_this_app_user_password@postgres:5432/smart_recommend_ai
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SIGNUP_BONUS_CREDITS=5
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Frontend (baked in at build time) ---
VITE_API_URL=http://localhost:5000/api
